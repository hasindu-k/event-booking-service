PORT=3000
MONGO_URI=mongodb://localhost:27017/event-booking-service
API_GATEWAY_URL=http://localhost:8086
GATEWAY_TIMEOUT_MS=5000
GATEWAY_USER_LOOKUP_PATH=/api/users/me
GATEWAY_EVENT_LOOKUP_PATH=/api/events/{eventId}
GATEWAY_EVENT_SEAT_UPDATE_PATH=/api/events/{eventId}/seats
GATEWAY_PAYMENT_CHARGE_PATH=/payments
GATEWAY_PAYMENT_REFUND_PATH=/payments/refund
GATEWAY_NOTIFICATION_EVENTS_PATH=/api/notifications/events
JWT_SECRET=your_jwt
INTERNAL_SERVICE_TOKEN=shared_service_secret
